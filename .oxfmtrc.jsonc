{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "tabWidth": 2,
  "printWidth": 80,
  "useTabs": false,
  "sortTailwindcss": {
    "stylesheet": "./src/styles/global.css",
    "functions": ["clsx", "cn", "tw", "tv"],
    "preserveWhitespace": true,
  },
  "ignorePatterns": ["worker-configuration.d.ts"],
}
