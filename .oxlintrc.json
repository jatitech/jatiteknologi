{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["unicorn", "typescript", "oxc"],
  "categories": {
    "correctness": "error",
    "perf": "error",
    "suspicious": "error"
  },
  "rules": {
    "eslint/no-unused-vars": "error"
  },
  "ignorePatterns": ["worker-configuration.d.ts"]
}
