{
  "$schema": "./node_modules/knip/schema.json",
  "ignoreFiles": ["src/paraglide/**"],
  "ignoreDependencies": [
    "@iconify-json/tabler",
    "@commitlint/cli",
    "@inlang/cli",
    "lefthook",
    "oxfmt",
    "oxlint",
    "oxlint-tsgolint",
    "wrangler"
  ],
  "ignoreBinaries": [
    "oxlint",
    "oxfmt",
    "commitlint",
    "astro",
    "paraglide-js",
    "wrangler",
    "inlang",
    "knip",
    "lefthook"
  ],
  "ignoreIssues": {
    "src/paraglide/**": ["exports", "types"],
    "src/components/ui/starwind/**": ["exports", "types"]
  },
  "typescript": {
    "config": ["tsconfig.json"]
  },
  "astro": {
    "config": ["astro.config.{js,cjs,mjs,ts,mts}"],
    "entry": [
      "src/content/config.ts",
      "src/content.config.ts",
      "src/pages/**/*.{astro,mdx,js,ts}",
      "!src/pages/**/_*",
      "!src/pages/**/_*/**",
      "src/content/**/*.mdx",
      "src/middleware.{js,ts}",
      "src/actions/index.{js,ts}"
    ]
  }
}
