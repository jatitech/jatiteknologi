---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/ui/sections/Header.astro";

const title = "Frappe Helpdesk: B2B E-Commerce";
const description = "Unified B2B ticketing on self-hosted Frappe Helpdesk.";
---

<Layout title={title} description={description}>
  <Header />
  <main class="container max-w-3xl py-24">
    <h1 class="text-4xl font-bold tracking-tight">{title}</h1>
    <p class="mt-4 text-muted-foreground">{description}</p>
  </main>
</Layout>
