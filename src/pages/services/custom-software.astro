---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/ui/sections/Header.astro";

const title = "Custom Software Development";
const description = "Bespoke, performance-critical applications built with a product-first engineering mindset.";
---

<Layout title={title} description={description}>
  <Header />
  <main class="container max-w-3xl py-24">
    <h1 class="text-4xl font-bold tracking-tight">{title}</h1>
    <p class="mt-4 text-muted-foreground">{description}</p>
  </main>
</Layout>
