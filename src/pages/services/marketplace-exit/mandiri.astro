---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/ui/sections/Header.astro";

const title = "Paket Mandiri";
const description = "Flagship marketplace exit (Rp 40-48 jt) — full platform independence with analytics, CRM, and WhatsApp commerce.";
---

<Layout title={title} description={description}>
  <Header />
  <main class="container max-w-3xl py-24">
    <h1 class="text-4xl font-bold tracking-tight">{title}</h1>
    <p class="mt-4 text-muted-foreground">{description}</p>
  </main>
</Layout>
