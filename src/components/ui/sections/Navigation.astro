---
import { getLocale } from "@/lib/i18n";
import { Button } from "@starwind/button";
import { getRelativeLocaleUrl } from "astro:i18n";
import {
  Item,
  ItemContent,
  ItemTitle,
  ItemDescription,
  ItemMedia,
  ItemGroup,
} from "@starwind/item";
import { getNavigation } from "@/configs/nav";

const locale = getLocale(Astro.currentLocale);

const navItems = getNavigation();
const navCount = navItems.length;

const DENSE_COLUMN_THRESHOLD = 5;
const PANEL_ID = "mega-menu-panel";
---

<mega-menu-nav
  class="hidden md:block relative"
  style={`--nav-count: ${navCount}`}
>
  <ul
    role="menubar"
    aria-label="Primary"
    class="md:flex items-center gap-1"
  >
    {
      navItems.map((item, idx) => (
        <li role="none">
          <Button
            {...(item.href
              ? { href: getRelativeLocaleUrl(locale, item.href) }
              : { type: "button" })}
            variant="ghost"
            size="sm"
            role="menuitem"
            title={item.label}
            data-index={idx}
            aria-haspopup={item.children?.length ? "true" : undefined}
            aria-expanded="false"
            aria-controls={item.children?.length ? PANEL_ID : undefined}
            class="mega-trigger"
          >
            {item.label}
          </Button>
        </li>
      ))
    }
  </ul>

  <!-- Shared Mega Menu Panel -->
  <div
    id={PANEL_ID}
    role="region"
    aria-label="Primary navigation panel"
    class="absolute top-full left-1/2 pt-4 w-[min(92vw,720px)] max-w-[calc(100vw-2rem)] z-50 invisible opacity-0"
    style="transform: translate(-50%, 8px);"
  >
    <!-- Hover bridge keeps the panel from closing while moving between trigger and panel -->
    <div
      class="absolute -top-4 left-0 right-0 h-8 bg-transparent"
      aria-hidden="true"
    ></div>

    <div
      class="bg-background backdrop-opacity-75 bg-clip-padding backdrop-filter backdrop-blur-xl text-popover-foreground rounded-xl shadow-lg border border-border overflow-hidden relative"
    >
      <!-- The viewport that clips the sliding track -->
      <div class="viewport relative w-full overflow-hidden">
        <!-- The track that slides horizontally -->
        <div
          class="track flex flex-row"
          style={`width: calc(100% * ${navCount})`}
        >
          {
            navItems.map((nav) => {
              const groupCount = nav.children?.length ?? 0;
              const isMultiGroup = groupCount > 1;
              const isDenseSingleGroup =
                groupCount === 1 &&
                (nav.children?.[0]?.items.length ?? 0) >
                  DENSE_COLUMN_THRESHOLD;
              return (
                <div
                  class:list={[
                    "pane p-5 sm:p-6 max-h-[min(70dvh,calc(100dvh-7rem))] overflow-y-auto overscroll-contain",
                    isMultiGroup && "flex flex-col gap-6",
                  ]}
                  style={`width: calc(100% / ${navCount})`}
                >
                  {nav.children?.map((item) => (
                    <div>
                      <h3 class="font-semibold mb-3 text-sm text-muted-foreground">
                        {item.label}
                      </h3>
                      <ItemGroup
                        class:list={[
                          isDenseSingleGroup
                            ? "grid grid-cols-1 lg:grid-cols-2 gap-x-4 gap-y-2"
                            : "gap-3",
                        ]}
                      >
                        {item.items.map((menu) => (
                          <Item
                            as="a"
                            href={getRelativeLocaleUrl(locale, menu.href)}
                            class="after:hidden"
                            title={menu.label}
                            aria-label={menu.label}
                          >
                            <ItemMedia
                              variant="icon"
                              class="group-hover/item:bg-linear-metal"
                            >
                              {menu.icon && <menu.icon />}
                            </ItemMedia>
                            <ItemContent>
                              <ItemTitle class="line-clamp-1">
                                {menu.label}
                              </ItemTitle>
                              {menu.description && (
                                <ItemDescription class="line-clamp-2">
                                  {menu.description}
                                </ItemDescription>
                              )}
                            </ItemContent>
                          </Item>
                        ))}
                      </ItemGroup>
                    </div>
                  ))}
                </div>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>
</mega-menu-nav>

<script>
  import gsap from "gsap";

  class MegaMenuNav extends HTMLElement {
    triggers: HTMLElement[];
    panel: HTMLElement | null;
    track: HTMLElement | null;
    closeTimeout: ReturnType<typeof setTimeout> | null;
    reducedMotion: MediaQueryList;

    constructor() {
      super();
      this.triggers = Array.from(
        this.querySelectorAll<HTMLElement>(".mega-trigger"),
      );
      this.panel = this.querySelector<HTMLElement>(`#${this.dataset.panelId || "mega-menu-panel"}`);
      this.track = this.querySelector<HTMLElement>(".track");
      this.closeTimeout = null;
      this.reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    }

    connectedCallback(): void {
      if (this.panel) {
        gsap.set(this.panel, { xPercent: -50, y: 8, autoAlpha: 0 });
      }
      this.init();
    }

    init(): void {
      this.triggers.forEach((trigger) => {
        trigger.addEventListener("mouseenter", (e) => this.handleEnter(e));
        trigger.addEventListener("focus", (e) => this.handleEnter(e));
        trigger.addEventListener("keydown", (e) => this.handleTriggerKey(e));
      });

      this.addEventListener("mouseleave", () => this.handleLeave());
      this.addEventListener("mouseenter", () => this.clearTimeout());

      this.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "Escape") {
          this.closeMenu();
          const expanded = this.triggers.find(
            (t) => t.getAttribute("aria-expanded") === "true",
          );
          (expanded ?? this.triggers[0])?.focus();
        }
      });

      document.addEventListener("click", (e) => {
        if (!this.contains(e.target as Node)) this.closeMenu();
      });
    }

    handleEnter(event: Event): void {
      this.clearTimeout();
      const trigger = event.target as HTMLElement;
      const index = Number.parseInt(trigger.dataset.index ?? "0", 10);
      this.openMenu(index);
    }

    handleLeave(): void {
      this.closeTimeout = setTimeout(() => this.closeMenu(), 300);
    }

    handleTriggerKey(event: KeyboardEvent): void {
      const last = this.triggers.length - 1;
      const current = this.triggers.indexOf(event.currentTarget as HTMLElement);
      let next = -1;
      switch (event.key) {
        case "ArrowRight":
          next = current === last ? 0 : current + 1;
          break;
        case "ArrowLeft":
          next = current === 0 ? last : current - 1;
          break;
        case "Home":
          next = 0;
          break;
        case "End":
          next = last;
          break;
        default:
          return;
      }
      event.preventDefault();
      this.triggers[next]?.focus();
    }

    clearTimeout(): void {
      if (this.closeTimeout) {
        clearTimeout(this.closeTimeout);
        this.closeTimeout = null;
      }
    }

    openMenu(index: number): void {
      this.triggers.forEach((t, i) => {
        const hasPopup = t.getAttribute("aria-haspopup") === "true";
        if (hasPopup) t.setAttribute("aria-expanded", (i === index).toString());
      });

      const reduce = this.reducedMotion.matches;

      if (this.panel) {
        gsap.to(this.panel, {
          autoAlpha: 1,
          y: 0,
          duration: reduce ? 0 : 0.3,
          ease: "back.out(1.2)",
          overwrite: "auto",
        });
      }

      if (this.track) {
        const count = this.triggers.length || 1;
        const percentage = (100 / count) * index;
        gsap.to(this.track, {
          xPercent: -percentage,
          duration: reduce ? 0 : 0.4,
          ease: "power3.inOut",
          overwrite: "auto",
        });
      }
    }

    closeMenu(): void {
      this.triggers.forEach((t) => t.setAttribute("aria-expanded", "false"));

      const reduce = this.reducedMotion.matches;
      if (this.panel) {
        gsap.to(this.panel, {
          autoAlpha: 0,
          y: 8,
          duration: reduce ? 0 : 0.2,
          ease: "power2.in",
          overwrite: "auto",
        });
      }
    }
  }

  if (!customElements.get("mega-menu-nav")) {
    customElements.define("mega-menu-nav", MegaMenuNav);
  }
</script>
