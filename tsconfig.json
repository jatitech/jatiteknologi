{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@starwind/*": [
        "src/components/ui/starwind/*"
      ]
    },
    "types": [
      "./worker-configuration.d.ts",
      "node"
    ]
  }
}
